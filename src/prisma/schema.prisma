enum Role {
  ADMIN
  STAFF
  USER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Int
  stock     Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Order {
  id        String   @id @default(uuid())
  total     Int
  status    String
  createdAt DateTime @default(now())
}

