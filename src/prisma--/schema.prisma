generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =========================
 * ENUMS
 * =========================
 */
enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ProductKind {
  SIMPLE        // produto fixo, preço/peso fixo
  CONFIGURABLE  // carnes/blocos com etapas
  BUNDLE        // kit/combos
}

enum AttributeInputType {
  RADIO
  SELECT
  CHECKBOX
  MULTISELECT
}

enum PriceModifierType {
  NONE
  FIXED     // soma direta em ienes (ex: -1000)
  PER_KG    // soma por kg (ex: +200 por kg)
  PERCENT   // porcentagem em cima do subtotal
}

/**
 * =========================
 * USERS
 * =========================
 */
model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  role     Role    @default(CUSTOMER)
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  orders    Order[]
}

/**
 * =========================
 * ADDRESS (JP friendly)
 * =========================
 */
model Address {
  id         String  @id @default(uuid())
  userId     String
  postalCode String
  prefecture String
  city       String
  address1   String
  address2   String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/**
 * =========================
 * CATEGORIES (com SEO + imagem)
 * =========================
 */
model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  image       String? // ex: "/uploads/categories/abc.webp"

  seoTitle       String?
  seoDescription String?

  parentId String?
  active   Boolean @default(true)
  sort     Int     @default(0)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  products ProductCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([active, sort])
}

/**
 * =========================
 * PRODUCTS
 * =========================
 * Regras:
 * - basePricePerKg: preço por kg do produto (carne/bloco)
 * - baseWeightKg: peso base usado no motor (normalmente 1kg)
 * - Para SIMPLE: você pode usar priceFixed e weightFixedKg
 * - Para CONFIGURABLE: usa basePricePerKg/baseWeightKg + atributos
 * - Para BUNDLE: itens em ProductBundleItem
 */
model Product {
  id          String      @id @default(uuid())
  name        String
  sku         String?     @unique
  description String?     @db.Text
  kind        ProductKind @default(SIMPLE)
  active      Boolean     @default(true)

  // SIMPLE (fixo)
  priceFixed    Int?
  weightFixedKg Float?

  // CONFIGURABLE (carne/bloco)
  basePricePerKg Int?
  baseWeightKg   Float? @default(1.0)
  minWeightKg    Float?
  maxWeightKg    Float?

  // Prazo base (se quiser já separar do frete)
  basePrepDays Int? @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories   ProductCategory[]
  attributes   ProductAttributeGroup[]
  stock        Stock?
  orderItems   OrderItem[]

  // BUNDLE
 
  bundleChildren ProductBundleItem[] @relation("BundleParent")
  bundleParents  ProductBundleItem[] @relation("BundleChild")
  bundleItems ProductBundleItem[] @relation("BundleParent")

  // Se quiser representar “Rump = alcatra + picanha”
  components ProductComponent[] @relation("ProductComponentsParent")

  @@index([active, kind])
}

/**
 * =========================
 * PRODUCT ↔ CATEGORY
 * =========================
 */
model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

/**
 * =========================
 * ATTRIBUTES (reutilizáveis, estilo Magento)
 * =========================
 * AttributeGroup = "passo" (ex: Tamanho da peça)
 * AttributeOption = opções do passo (ex: 4.5kg, 7.5kg)
 * ProductAttributeGroup = liga produto aos passos e define ordem/condições
 */
model AttributeGroup {
  id        String             @id @default(uuid())
  name      String             // ex: "Tamanho da peça"
  code      String             @unique // ex: "SIZE", "CUT_PREF", "CUT_STYLE"
  inputType AttributeInputType
  required  Boolean            @default(false)
  sort      Int                @default(0)

  // regras/condições globais do grupo (opcional)
  condition Json?

  options   AttributeOption[]
  products  ProductAttributeGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sort])
}

model AttributeOption {
  id        String  @id @default(uuid())
  groupId   String
  label     String  // ex: "Média 4.5kg"
  sku       String? // sku interno do option (opcional)
  sort      Int     @default(0)

  // PREÇO
  priceModifierType  PriceModifierType @default(NONE)
  priceModifierValue Int? // ienes (FIXED/PER_KG) ou % (PERCENT)

  // PESO
  // Para o seu caso “peça média 4.5kg”: weightMultiplier = 4.5
  weightMultiplier Float?
  // delta/override extras se precisar
  weightDeltaKg    Float?
  weightOverrideKg Float?

  // PRAZO
  extraPrepDays Int? @default(0)

  // regras tipo yield etc
  yieldRules Json?

  group AttributeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId, sort])
}

model ProductAttributeGroup {
  id        String  @id @default(uuid())
  productId String
  groupId   String

  // ordem do passo no produto (1,2,3…)
  stepOrder Int     @default(0)

  // overrides por produto
  requiredOverride Boolean?
  condition        Json? // condição para aparecer (ex: só se CUT_PREF = "cortes personalizados")

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  group   AttributeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([productId, groupId])
  @@index([productId, stepOrder])
}

/**
 * =========================
 * BUNDLE (kit/combos)
 * =========================
 */
model ProductBundleItem {
  id              String @id @default(uuid())
  bundleId        String
  childProductId  String
  quantity        Int @default(1)

  bundle Product @relation(
    "BundleParent",
    fields: [bundleId],
    references: [id],
    onDelete: Cascade
  )

  child Product @relation(
    "BundleChild",
    fields: [childProductId],
    references: [id],
    onDelete: Cascade
  )

  @@unique([bundleId, childProductId])
}

/**
 * =========================
 * PRODUCT COMPONENTS (ex: Rump = Alcatra + Picanha)
 * =========================
 * Opcional, mas resolve seu caso de "2 carnes no mesmo bloco".
 */
model ProductComponent {
  id            String @id @default(uuid())
  parentId      String
  componentName String // ex: "Alcatra", "Picanha"
  sort          Int    @default(0)

  parent Product @relation("ProductComponentsParent", fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId, sort])
}

/**
 * =========================
 * STOCK
 * =========================
 */
model Stock {
  id        String @id @default(uuid())
  productId String @unique
  quantity  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/**
 * =========================
 * ORDERS
 * =========================
 */
model Order {
  id     String      @id @default(uuid())
  userId String
  status OrderStatus @default(PENDING)
  total  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  items   OrderItem[]
  payment Payment?

  @@index([userId, createdAt])
}

/**
 * =========================
 * ORDER ITEMS
 * =========================
 * Guarda snapshot do produto/seleções e cálculo final.
 */
model OrderItem {
  id            String @id @default(uuid())
  orderId       String
  productId     String
  quantity      Int

  // snapshot base
  productName   String
  productSku    String?
  basePricePerKg Int?
  baseWeightKg   Float?

  // resultado do motor
  finalWeightKg Float?
  unitPrice     Int // preço unitário final já calculado (por item)
  total         Int // unitPrice * quantity

  // prazo calculado (pra empurrar calendário)
  extraPrepDays Int? @default(0)

  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  selections OrderItemSelection[]

  @@index([orderId])
  @@index([productId])
}

model OrderItemSelection {
  id          String @id @default(uuid())
  orderItemId String

  groupId   String?
  optionId  String?
  groupCode String?
  groupName String?
  optionLabel String?

  // impactos já aplicados (snapshot)
  priceImpact    Int?   // ienes
  weightImpactKg Float? // kg
  extraPrepDays  Int?   // dias

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
}

/**
 * =========================
 * PAYMENTS
 * =========================
 */
model Payment {
  id      String        @id @default(uuid())
  orderId String        @unique
  method  String
  status  PaymentStatus @default(PENDING)
  amount  Int

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}